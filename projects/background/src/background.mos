    ]

    -- The walker: two 8x8 GB 2bpp frames of a little knight mid-stride
    -- (colour 0 transparent, 2 = shaded face, 3 = body), drawn facing right.
    -- Frame 0 = legs apart, frame 1 = legs passing; FLIP_X mirrors it when
    -- walking left -- the Running Knight idiom of swapping animation frames
    -- on a fixed sprite slot.
    const WALKER_TILES: array[u8, 32] = [
        0x18, 0x18, 0x3C, 0x3C, 0x00, 0x18, 0x7E, 0x7E, 0x3C, 0x3C, 0x18, 0x18, 0x24, 0x24, 0x42, 0x42,
        0x18, 0x18, 0x3C, 0x3C, 0x00, 0x18, 0x7E, 0x7E, 0x3C, 0x3C, 0x18, 0x18, 0x18, 0x18, 0x28, 0x28
    ]

    -- Background scroll offset in pixels (wraps mod 256 = the map size).
    var bx: u8 = 0
    var by: u8 = 0

    -- Walk-cycle clock: advanced only while scrolling, swaps the walker's
    -- animation frame every 8 ticks.
    var step: u8 = 0

    function main() {
        bkg.set_data(0, 95, TILESET)
        bkg.set_tiles(0, 0, TILEMAP_WIDTH, TILEMAP_HEIGHT, TILEMAP)

        sprite.set_data(0, 2, WALKER_TILES)
        sprite.set_tile(0, 0)
        sprite.set_palette(0, 0)
        sprite.move(0, SCREEN_WIDTH / 2 - 4, SCREEN_HEIGHT / 2 - 4)

        -- One palette for the whole scene (graphics.palette degrades to the
        -- same grey ramp on the 4-grey consoles, so the look is unchanged on
        -- Game Boy / Mega Duck but the colour consoles get a daylight scene
        -- instead of an undefined default palette). Each colour is chosen so
        -- (a) its luminance still lands in the matching DMG shade (0 lit .. 3
        -- darkest), so the Game Boy picture is identical to before, and (b) it
        -- stays clearly *green* even after 2-bit-per-channel quantization on the
        -- SMS/Game Gear (RGB222) and on the NES master palette -- a muddy green
        -- like (64,120,72) collapses to grey there (its R/G/B share the same top
        -- 2 bits), so the dark tree tops would read as grey; a green-dominant
        -- value keeps them green.
        palette.set_bkg(0, palette.rgb(230, 245, 255), palette.rgb(96, 208, 96), palette.rgb(88, 160, 40), palette.rgb(24, 40, 32))
        -- Walker: colour 0 transparent, 2 the shaded face, 3 the body.
        palette.set_sprite(0, palette.rgb(0, 0, 0), palette.rgb(240, 224, 176), palette.rgb(170, 120, 90), palette.rgb(40, 52, 120))

        video.enable_lcd()
        video.show_background()
        video.show_sprites()

        loop {
            var moving: u8 = 0

            if input.held(INPUT_UP)    { by -= 1  moving = 1 }
            if input.held(INPUT_DOWN)  { by += 1  moving = 1 }
            if input.held(INPUT_LEFT)  {
                bx -= 1
                moving = 1
                sprite.set_prop(0, FLIP_X)
            }
            if input.held(INPUT_RIGHT) {
                bx += 1
                moving = 1
                sprite.set_prop(0, 0)
            }

            if input.held(INPUT_START) or input.held(INPUT_A) {
                bx = 0
                by = 0
            }

            -- Stride while the world scrolls, stand still otherwise.
            if moving == 1 {
                step += 1
                sprite.set_tile(0, step / 8 % 2)
            } else {
                sprite.set_tile(0, 0)
            }

            bkg.move(bx, by)
            video.wait_vblank()
        }
    }

    export main
}
