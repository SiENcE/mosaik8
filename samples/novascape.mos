    -- Manual amendment to the generated code: the game's logic lives in GB
    -- OAM coordinates, but sprite.move now takes screen-pixel coordinates
    -- (origin = top-left of the visible screen). This shim subtracts the GB
    -- OAM offset; u8 wrap-around makes it byte-exact with the old lowering,
    -- including the hide-at-(0,0) idiom.
    local function moveOAM(id: u8, x: u8, y: u8) {
        sprite.move(id, x - 8, y - 16)
