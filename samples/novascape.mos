    -- Game Boy sound register addresses (for raw hw.write).
    const NR11: addr = 0xFF11
    const NR12: addr = 0xFF12
    const NR13: addr = 0xFF13
    const NR14: addr = 0xFF14
    const NR21: addr = 0xFF16
    const NR22: addr = 0xFF17
    const NR23: addr = 0xFF18
    const NR24: addr = 0xFF19
    const NR41: addr = 0xFF20
    const NR42: addr = 0xFF21
    const NR43: addr = 0xFF22
    const NR44: addr = 0xFF23
    const NR50: addr = 0xFF24
    const NR51: addr = 0xFF25
    const NR52: addr = 0xFF26

    -- Sprite property flags combined (FLIP_X | FLIP_Y).
    const FLIP_XY: u8 = 96

    -- === game state =========================================================
    var state: u8 = 0          -- 0 TITLE, 1 HOWTO, 2 PLAY, 3 ENDING
    var entering: u8 = 1       -- 1 = run this state's one-time init next frame
    var kk: u16 = 0
    var cooldown: u8 = 0
    var frame: u8 = 0

    var difficulty: u8 = 0
    var win: u8 = 0
    var lives: u8 = 3
    var fuel: u16 = 40000

    var playMusicPlease: u8 = 0
    var musicposn: u16 = 0
    var musiccounter: u16 = 0
    var bassmusicposn: u16 = 0
    var bassmusiccounter: u16 = 0

    var fuelCanX: u8 = 0
    var fuelCanY: u8 = 0
    var fuelCanActive: u8 = 0
    var fuelGet: u8 = 0
    var playSiren: u8 = 0
    var sfxr: u8 = 0

    var enemyX: array[u8, 7]
    var enemyY: array[u8, 7]
    var enemyType: array[u8, 7]

    var flameHeight: u8 = 0
    var moveFlame: u8 = 0

    var playerDir: u8 = 0
    var playerX: u8 = 76
    var playerY: u8 = 66
    var playerVelocity: u8 = 128
    var thrustAmount: i8 = 0

    var dist: array[u8, 4]
    var shotX: u8 = 255
    var shotY: u8 = 0
    var shotDir: u8 = 0
    var shotLife: u8 = 0

    var levelStarted: u8 = 0

    -- victory-screen animation state
    var vi: u8 = 0
    var vj: u8 = 0
    var vk: u8 = 0
    var vl: u8 = 0

    -- === shared helpers (solar.c) ==========================================
    local function collision_check(x1: u8, y1: u8, w1: u8, h1: u8, x2: u8, y2: u8, w2: u8, h2: u8) -> u8 {
        if x1 < x2 + w2 and x1 + w1 > x2 and y1 < h2 + y2 and y1 + h1 > y2 {
            return 1
        }
        return 0
    }

    local function play_music() {
        musiccounter += 1
        if musiccounter > music[musicposn + 2] {
            if music[musicposn] == 0 {
                hw.write(NR11, 0)
                hw.write(NR12, 0)
                hw.write(NR13, 0)
                hw.write(NR14, 0)
            } else {
                hw.write(NR11, 0xC0)
                hw.write(NR12, 0x3F)
                hw.write(NR13, music[musicposn + 1])
                hw.write(NR14, music[musicposn])
            }
            musicposn += 3
            musiccounter = 0
            if musicposn >= 282 { musicposn = 0 }
        }
        bassmusiccounter += 1
        if bassmusiccounter > bassmusic[bassmusicposn + 2] {
            if bassmusic[bassmusicposn] == 0 {
                hw.write(NR21, 0)
                hw.write(NR22, 0)
                hw.write(NR23, 0)
                hw.write(NR24, 0)
            } else {
                hw.write(NR21, 0xC0)
                hw.write(NR22, 0x3F)
                hw.write(NR23, bassmusic[bassmusicposn + 1])
                hw.write(NR24, bassmusic[bassmusicposn])
            }
            bassmusicposn += 3
            bassmusiccounter = 0
            if bassmusicposn >= 48 { bassmusicposn = 0 }
        }
    }

    local function fade_in_bkg(d: u16) {
        hw.write(REG_BGP, 0x00)
        system.delay(d)
        video.show_background()
        hw.write(REG_BGP, 0x54)
        video.show_background()
        system.delay(d)
        hw.write(REG_BGP, 0xA4)
        video.show_background()
        system.delay(d)
        hw.write(REG_BGP, 0xE4)
        video.show_background()
    }

    local function fade_out_bkg(d: u16) {
        hw.write(REG_BGP, 0xE4)
        system.delay(d)
        video.show_background()
        hw.write(REG_BGP, 0xA4)
        video.show_background()
        system.delay(d)
        hw.write(REG_BGP, 0x54)
        video.show_background()
        system.delay(d)
        hw.write(REG_BGP, 0x00)
        video.show_background()
    }

    local function fade_in_sprites(d: u16) {
        hw.write(REG_OBP0, 0x00)
        system.delay(d)
        video.show_sprites()
        hw.write(REG_OBP0, 0x54)
        video.show_sprites()
        system.delay(d)
        hw.write(REG_OBP0, 0xA4)
        video.show_sprites()
        system.delay(d)
        hw.write(REG_OBP0, 0xE4)
        video.show_sprites()
    }

    local function reset_bkg_tiles() {
        bkg.set_tiles(0, 0, 20, 32, gameBKG)
    }

    -- === state transitions ==================================================
    local function go_title() { state = 0  entering = 1 }
    local function go_howto() { state = 1  entering = 1 }
    local function go_play()  { state = 2  entering = 1 }
    local function go_ending(){ state = 3  entering = 1 }

    -- === PLAY: helpers (rombank1.c) ========================================
    local function update_win_data() {
        for v in 2..18 {
            winData[v] = 22 + system.random() % 3
        }
        window.set_tiles(0, 0, 21, 1, winData)
    }

    local function update_sprite() {
        collision_check_all()
        switch playerDir {
            case 0 {
                moveOAM(0, playerX, playerY)
                moveOAM(1, playerX + 8, playerY)
                moveOAM(2, playerX, playerY + 8)
                moveOAM(3, playerX + 8, playerY + 8)
                moveOAM(4, playerX, playerY + 16)
                moveOAM(5, playerX + 8, playerY + 16)
            }
            case 1 {
                moveOAM(0, playerX + 8, playerY)
                moveOAM(1, playerX, playerY)
                moveOAM(2, playerX + 8, playerY + 8)
                moveOAM(3, playerX, playerY + 8)
                moveOAM(4, playerX + 8, playerY + 16)
                moveOAM(5, playerX, playerY + 16)
            }
        }
    }

    local function show_flame() {
        switch playerDir {
            case 0 { moveOAM(6, playerX - 1, playerY + 17) }
            case 1 { moveOAM(6, playerX + 10, playerY + 17) }
        }
        sprite.set_tile(6, 12 + hw.read(REG_DIV) % 3)
    }

    local function hide_flame() {
        moveOAM(6, 0, 0)
    }

    local function update_distance() {
        dist[3] -= 1
        if dist[3] == 255 { dist[3] = 9  dist[2] -= 1 }
        if dist[2] == 255 { dist[2] = 9  dist[1] -= 1 }
        if dist[1] == 255 { dist[1] = 9  dist[0] -= 1  thinnen_play_field() }
        if dist[0] == 255 { dist[0] = 0  win_game() }
        sprite.set_tile(7, dist[0])
        sprite.set_tile(8, dist[1])
        sprite.set_tile(9, dist[2])
        sprite.set_tile(10, dist[3])
    }

    local function update_scrolls() {
        shotY += 1
        for v in 0..7 {
            if enemyType[v] == 1 { enemyY[v] += 1 }
        }
    }

    local function instantiate_enemy() {
        var j: u8 = hw.read(REG_DIV) % 7
        switch j {
            case 0 {
                if enemyType[0] == 0 {
                    enemyType[0] = 1
                    enemyY[0] = 150
                    enemyX[0] = 60 + system.random() % 40
                }
            }
            case 1 {
                if enemyType[1] == 0 {
                    enemyType[1] = 1
                    enemyY[1] = 200 + hw.read(REG_DIV) % 55
                    enemyX[1] = 180
                }
            }
            case 2 {
                if enemyType[2] == 0 {
                    enemyType[2] = 1
                    enemyY[2] = 240 + hw.read(REG_DIV) % 55
                    enemyX[2] = 180
                }
            }
            case 3, 5 {
                if enemyType[j] == 0 {
                    enemyType[j] = 1
                    enemyY[j] = 0 + hw.read(REG_DIV) % 55
                    enemyX[j] = 180
                }
            }
            case 4, 6 {
                if enemyType[j] == 0 {
                    enemyType[j] = 1
                    enemyY[j] = 50 + hw.read(REG_DIV) % 55
                    enemyX[j] = 0
                }
            }
        }
    }

    local function move_enemies() {
        if enemyType[0] == 1 {
            if difficulty == 0 {
                if frame % 3 == 0 { enemyY[0] -= 1 }
            } else {
                if frame % 2 == 0 { enemyY[0] -= 1 }
            }
            if enemyY[0] == 220 { enemyType[0] = 0  enemyX[0] = 180  enemyY[0] = 180 }
        }
        if enemyType[1] == 1 {
            enemyX[1] += 1
            if enemyX[1] == 180 { enemyType[1] = 0 }
        }
        if enemyType[2] == 1 {
            if frame % 3 == 0 { enemyX[2] += 1 }
            if frame % 5 == 0 {
                if enemyY[2] < playerY + 3 { enemyY[2] += 1 }
                if enemyY[2] > playerY + 5 { enemyY[2] -= 1 }
            }
            if enemyX[2] == 180 { enemyType[2] = 0 }
        }
        if enemyType[3] == 1 {
            if frame % 2 == 0 { enemyX[3] -= 1 }
            if enemyX[3] == 242 { enemyType[3] = 0 }
        }
        if enemyType[4] == 1 {
            if frame % 2 == 0 { enemyX[4] += 1 }
            if enemyX[4] == 180 { enemyType[4] = 0 }
        }
        if enemyType[5] == 1 {
            if frame % 2 == 0 { enemyX[5] -= 1 }
            if enemyX[5] == 242 { enemyType[5] = 0 }
        }
        if enemyType[6] == 1 {
            if frame % 2 == 0 { enemyX[6] += 1 }
            if enemyX[6] == 180 { enemyType[6] = 0 }
        }
        if frame % 32 == 16 {
            if sprite.get_tile(20) == 33 {
                sprite.set_tile(20, 34)
                sprite.set_tile(21, 34)
                sprite.set_tile(22, 34)
                sprite.set_tile(23, 34)
                sprite.set_tile(25, 26)
                sprite.set_tile(26, 26)
            } else {
                sprite.set_tile(20, 33)
                sprite.set_tile(21, 33)
                sprite.set_tile(22, 33)
                sprite.set_tile(23, 33)
                sprite.set_tile(25, 27)
                sprite.set_tile(26, 27)
            }
            switch hw.read(REG_DIV) % 4 {
                case 0 { sprite.set_prop(24, FLIP_XY) }
                case 1 { sprite.set_prop(24, FLIP_X) }
                case 2 { sprite.set_prop(24, FLIP_Y) }
                case 3 { sprite.set_prop(24, 0) }
            }
        }
        if frame % 6 == 3 {
            if sprite.get_tile(28) == 23 {
                sprite.set_tile(28, 24)
                sprite.set_tile(30, 23)
                sprite.set_tile(32, 24)
                sprite.set_tile(34, 23)
            } else {
                sprite.set_tile(30, 24)
                sprite.set_tile(28, 23)
                sprite.set_tile(32, 23)
                sprite.set_tile(34, 24)
            }
        }
    }

    local function collision_check_gun() {
        for v in 0..7 {
            if enemyType[v] == 1 {
                switch v {
                    case 0 {
                        if collision_check(enemyX[v] + 2, enemyY[v] + 2, 12, 12, shotX, shotY, 8, 3) == 1 {
                            enemyType[v] = 0
                            if difficulty == 0 {
                                fuelCanActive = 1
                                fuelCanX = enemyX[v]
                                fuelCanY = enemyY[v]
                            }
                            enemyX[v] = 0
                            enemyY[v] = 200
                            sfxr = 35
                        }
                    }
                    case 2 {
                        if collision_check(enemyX[v] + 2, enemyY[v] + 2, 14, 6, shotX, shotY, 8, 3) == 1 {
                            enemyType[v] = 0
                            fuelCanActive = 1
                            fuelCanX = enemyX[v]
                            fuelCanY = enemyY[v]
                            enemyX[v] = 0
                            enemyY[v] = 200
                            sfxr = 35
                        }
                    }
                    case 1, 3, 4, 5, 6 {
                        if collision_check(enemyX[v] + 1, enemyY[v] + 1, 6, 6, shotX, shotY, 8, 3) == 1 {
                            enemyType[v] = 0
                            fuelCanActive = 1
                            fuelCanX = enemyX[v]
                            fuelCanY = enemyY[v]
                            enemyX[v] = 0
                            enemyY[v] = 200
                            sfxr = 35
                        }
                    }
                }
            }
        }
    }

    local function collision_check_all() {
        if difficulty == 1 {
            switch dist[0] {
                case 5 { if playerX < 16 { player_died() }  if playerX > 144 { player_died() } }
                case 4 { if playerX < 24 { player_died() }  if playerX > 136 { player_died() } }
                case 3 { if playerX < 32 { player_died() }  if playerX > 128 { player_died() } }
                case 2 { if playerX < 40 { player_died() }  if playerX > 120 { player_died() } }
                case 1 { if playerX < 48 { player_died() }  if playerX > 112 { player_died() } }
                case 0 { if playerX < 54 { player_died() }  if playerX > 104 { player_died() } }
            }
        } else {
            if playerX < 16 { player_died() }
            if playerX > 144 { player_died() }
        }

        if playerY + 4 > flameHeight { player_died() }

        var lo: u8 = playerX - 16
        var hi: u8 = playerX + 16

        if fuelCanActive == 1 {
            if collision_check(fuelCanX + 1, fuelCanY + 1, 6, 6, playerX + 3, playerY + 2, 8, 17) == 1 {
                if difficulty == 1 {
                    fuel += 1000
                    if fuel > 40001 { fuel = 40001 }
                } else {
                    fuel += 1250
                    if fuel > 41001 { fuel = 41001 }
                }
                var kt: u8 = sprite.get_tile(37)
                kt -= 5
                if kt < 57 { kt = 57 }
                sprite.set_tile(37, kt)
                fuelCanActive = 0
                fuelCanX = 0
                fuelCanY = 0
                fuelGet = 255
                moveOAM(35, fuelCanX, fuelCanY)
            }
        }

        if enemyType[0] == 1 {
            if enemyX[0] > lo and enemyX[0] < hi {
                if collision_check(enemyX[0] + 2, enemyY[0] + 2, 12, 12, playerX + 3, playerY + 2, 8, 15) == 1 { player_died() }
            }
        }
        if enemyType[1] == 1 {
            if enemyX[1] > lo and enemyX[1] < hi {
                if collision_check(enemyX[1] + 1, enemyY[1] + 1, 6, 6, playerX + 3, playerY + 2, 8, 15) == 1 { player_died() }
            }
        }
        if enemyType[2] == 1 {
            if enemyX[2] > lo and enemyX[2] < hi {
                if collision_check(enemyX[2] + 1, enemyY[2] + 1, 14, 6, playerX + 3, playerY + 2, 8, 15) == 1 { player_died() }
            }
        }
        for v in 3..7 {
            if enemyType[v] == 1 {
                if enemyX[v] > lo and enemyX[v] < hi {
                    if collision_check(enemyX[v] + 1, enemyY[v] + 1, 6, 6, playerX + 3, playerY + 2, 8, 15) == 1 { player_died() }
                }
            }
        }
    }

    local function update_fuel_can() {
        if fuelCanActive == 1 {
            if frame % 5 == 3 {
                sprite.set_tile(35, 54 + hw.read(REG_DIV) % 3)
                if fuelCanX < playerX + 8 { fuelCanX += 1 } else { fuelCanX -= 1 }
                if fuelCanY < playerY + 8 { fuelCanY += 1 } else { fuelCanY -= 1 }
                moveOAM(35, fuelCanX, fuelCanY)
            }
        } else {
            fuelCanX = 0
            fuelCanY = 0
        }
    }

    local function thinnen_play_field() {
        if difficulty == 1 {
            if 5 - dist[0] < 240 { bkg.set_tiles(5 - dist[0], 0, 1, 32, blankColLeft) }
            if 4 - dist[0] < 240 { bkg.set_tiles(4 - dist[0], 0, 1, 32, blankColGreyLeft) }
            if 3 - dist[0] < 240 { bkg.set_tiles(3 - dist[0], 0, 1, 32, blankColBlack) }
            if 2 - dist[0] < 240 { bkg.set_tiles(2 - dist[0], 0, 1, 32, blankColBlack) }
            if 1 - dist[0] < 240 { bkg.set_tiles(1 - dist[0], 0, 1, 32, blankColBlack) }
            bkg.set_tiles(14 + dist[0], 0, 1, 32, blankCol)
            bkg.set_tiles(15 + dist[0], 0, 1, 32, blankColGrey)
            bkg.set_tiles(16 + dist[0], 0, 1, 32, blankColBlack)
            bkg.set_tiles(17 + dist[0], 0, 1, 32, blankColBlack)
            bkg.set_tiles(18 + dist[0], 0, 1, 32, blankColBlack)
            bkg.set_tiles(19 + dist[0], 0, 1, 32, blankColBlack)
            bkg.set_tiles(20 + dist[0], 0, 1, 32, blankColBlack)
        }
    }

    local function player_died() {
        lives -= 1
        hw.write(NR41, 0x7F)
        hw.write(NR42, 0x7F)
        hw.write(NR43, 0x7F - hw.read(REG_DIV) % 5)
        hw.write(NR44, 0x81)
        hw.write(NR11, 0)
        hw.write(NR12, 0)
        hw.write(NR13, 0)
        hw.write(NR14, 0)
        hw.write(NR21, 0)
        hw.write(NR22, 0)
        hw.write(NR23, 0)
        hw.write(NR24, 0)
        for v in 0..64 {
            hw.write(REG_OBP0, system.random())
            hw.write(REG_BGP, system.random())
            system.delay(4)
            hw.write(NR43, hw.read(REG_DIV))
            video.show_background()
            video.show_sprites()
        }
        hw.write(NR41, 0)
        hw.write(NR42, 0)
        hw.write(NR43, 0)
        hw.write(NR44, 0)
        video.hide_sprites()
        hw.write(REG_OBP0, 0xE4)
        if lives == 0 {
            fade_out_bkg(255)
            win = 0
            reset_bkg_tiles()
            go_ending()
        } else {
            fade_out_bkg(32)
            go_play()
        }
    }

    local function win_game() {
        hw.write(NR11, 0)
        hw.write(NR12, 0)
        hw.write(NR13, 0)
        hw.write(NR14, 0)
        hw.write(NR21, 0)
        hw.write(NR22, 0)
        hw.write(NR23, 0)
        hw.write(NR24, 0)
        hw.write(NR41, 0)
        hw.write(NR42, 0)
        hw.write(NR43, 0)
        hw.write(NR44, 0)
        fade_out_bkg(255)
        win = 1
        go_ending()
    }

    -- === PLAY: init + per-frame (rombank1.c updateGame) =====================
    local function play_init() {
        shotLife = 0
        video.hide_sprites()
        flameHeight = 0
        playerDir = 0
        bkg.move(0, 0)
        fuelGet = 0
        fuel = 40000
        hw.write(NR11, 0)
        hw.write(NR12, 0)
        hw.write(NR13, 0)
        hw.write(NR14, 0)
        hw.write(NR21, 0)
        hw.write(NR22, 0)
        hw.write(NR23, 0)
        hw.write(NR24, 0)
        hw.write(NR41, 0)
        hw.write(NR42, 0)
        hw.write(NR43, 0)
        hw.write(NR44, 0)
        for v in 0..7 {
            enemyType[v] = 0
            enemyY[v] = 0
            enemyX[v] = 0
        }
        levelStarted = 0
        for v in 0..40 {
            moveOAM(v, 0, 0)
            sprite.set_prop(v, 0)
        }
        window.set_tiles(0, 0, 21, 1, winData)
        for v in 1..32 {
            window.set_tiles(0, v, 21, 1, blankLine)
        }
        window.move(7, flameHeight)
        for v in 16..20 {
            sprite.set_tile(v, 28)
            moveOAM(v, 64 + (v - 16) * 8, 86)
        }
        for v in 32..39 {
            sprite.set_tile(v, 29)
            moveOAM(v, 72, 94 + (v - 32) * 8)
        }
        for v in 22..29 {
            sprite.set_tile(v, 29)
            moveOAM(v, 80, 94 + (v - 22) * 8)
        }
        sprite.set_tile(7, dist[0])
        sprite.set_tile(8, dist[1])
        sprite.set_tile(9, dist[2])
        sprite.set_tile(10, dist[3])
        moveOAM(7, 68, 20)
        moveOAM(8, 76, 20)
        moveOAM(9, 84, 20)
        moveOAM(10, 92, 20)
        sprite.set_tile(0, 10)
        sprite.set_tile(1, 11)
        sprite.set_tile(2, 20)
        sprite.set_tile(3, 21)
        sprite.set_tile(4, 30)
        sprite.set_tile(5, 31)
        sprite.set_prop(0, 0)
        sprite.set_prop(1, 0)
        sprite.set_prop(2, 0)
        sprite.set_prop(3, 0)
        sprite.set_prop(4, 0)
        sprite.set_prop(5, 0)
        playerX = 76
        playerY = 66
        playerVelocity = 128
        thrustAmount = 0
        sprite.set_tile(6, 12)
        moveOAM(0, playerX, playerY)
        moveOAM(1, playerX + 8, playerY)
        moveOAM(2, playerX, playerY + 8)
        moveOAM(3, playerX + 8, playerY + 8)
        moveOAM(4, playerX, playerY + 16)
        moveOAM(5, playerX + 8, playerY + 16)
        fade_in_bkg(32)
        hw.write(NR41, 0)
        hw.write(NR42, 0)
        hw.write(NR43, 0)
        hw.write(NR44, 0)
    }

    local function play_intro() {
        sfxr = 0
        thinnen_play_field()
        if flameHeight != 132 {
            hw.write(NR41, 0x7F)
            hw.write(NR42, 0x3F)
            hw.write(NR43, 0x5F - hw.read(REG_DIV) % 5)
            hw.write(NR44, 0x81)
            flameHeight += 1
            window.move(7, flameHeight)
            bkg.scroll(0, 1)
            video.hide_sprites()
        } else {
            hw.write(NR41, 0)
            hw.write(NR42, 0)
            hw.write(NR43, 0)
            hw.write(NR44, 0)
            fade_in_sprites(32)
            video.show_sprites()
            while true {
                frame += 1
                if input.pressed(INPUT_A) {
                    for v in 16..40 {
                        moveOAM(v, 0, 0)
                    }
                    sprite.set_tile(11, 25)
                    shotX = 255
                    shotY = 0
                    moveOAM(11, shotX, shotY)
                    sprite.set_tile(20, 33)
                    sprite.set_tile(21, 33)
                    sprite.set_tile(22, 33)
                    sprite.set_tile(23, 33)
                    sprite.set_prop(21, FLIP_X)
                    sprite.set_prop(22, FLIP_Y)
                    sprite.set_prop(23, FLIP_XY)
                    sprite.set_tile(24, 35)
                    sprite.set_tile(25, 26)
                    sprite.set_tile(26, 26)
                    sprite.set_prop(26, FLIP_X)
                    sprite.set_tile(27, 22)
                    sprite.set_tile(28, 23)
                    sprite.set_tile(29, 22)
                    sprite.set_tile(30, 23)
                    sprite.set_prop(29, FLIP_X)
                    sprite.set_prop(30, FLIP_X)
                    sprite.set_tile(31, 22)
                    sprite.set_tile(32, 23)
                    sprite.set_tile(33, 22)
                    sprite.set_tile(34, 23)
                    sprite.set_prop(33, FLIP_X)
                    sprite.set_prop(34, FLIP_X)
                    sprite.set_tile(35, 54)
                    moveOAM(35, 0, 0)
                    fuelCanActive = 0
                    fuelCanX = 0
                    fuelCanY = 0
                    sprite.set_tile(36, 66)
                    moveOAM(36, 88, 132)
                    sprite.set_tile(37, 57)
                    moveOAM(37, 80, 132)
                    sprite.set_tile(12, 67)
                    moveOAM(12, 72, 132)
                    sprite.set_tile(38, 54 - lives)
                    moveOAM(38, 56, 132)
                    levelStarted = 1
                    break
                }
                if frame % 120 == 1 {
                    update_win_data()
                    video.show_window()
                }
            }
        }
        if frame % 2 == 1 {
            update_win_data()
        }
    }

    local function play_game() {
        collision_check_gun()
        if sfxr != 0 {
            sfxr -= 1
            hw.write(NR41, 0x7F)
            hw.write(NR42, sfxr * 10)
            hw.write(NR43, 0x4F - sfxr * 2)
            hw.write(NR44, 0x81)
        }
        if frame % 55 == 0 {
            instantiate_enemy()
        }
        if fuelGet != 0 {
            fuelGet -= 5
            hw.write(NR21, 0x7F)
            hw.write(NR22, 0x7F)
            hw.write(NR23, 255 - fuelGet)
            hw.write(NR24, 0x86)
        } else {
            hw.write(NR21, 0)
            hw.write(NR22, 0)
            hw.write(NR23, 0)
            hw.write(NR24, 0)
        }
        if playSiren != 0 {
            playSiren -= 1
            hw.write(NR21, 0x7F)
            hw.write(NR22, 0x7F)
            hw.write(NR23, (32 - playSiren) * 16)
            hw.write(NR24, 0x86)
        } else {
            if fuelGet == 0 {
                hw.write(NR21, 0)
                hw.write(NR22, 0)
                hw.write(NR23, 0)
                hw.write(NR24, 0)
            }
        }
        move_enemies()
        if input.pressed(INPUT_B) {
            if playerDir == 0 {
                playerDir = 1
                for v in 0..6 {
                    sprite.set_prop(v, FLIP_X)
                }
                update_sprite()
            }
        } else {
            if playerDir == 1 {
                playerDir = 0
                for v in 0..6 {
                    sprite.set_prop(v, 0)
                }
                update_sprite()
            }
        }
        update_fuel_can()
        if input.pressed(INPUT_A) and fuel != 38400 {
            fuel -= 1
            switch fuel {
                case 40000 { sprite.set_tile(37, 57) }
                case 39800 { sprite.set_tile(37, 58) }
                case 39600 { sprite.set_tile(37, 59) }
                case 39400 { sprite.set_tile(37, 60) }
                case 39200 { sprite.set_tile(37, 61) }
                case 39000 { sprite.set_tile(37, 62)  playSiren = 32 }
                case 38800 { sprite.set_tile(37, 63) }
                case 38600 { sprite.set_tile(37, 64)  playSiren = 64 }
                case 38400 { sprite.set_tile(37, 65) }
            }
            hw.write(NR41, 0x7F)
            hw.write(NR42, 0x1F)
            hw.write(NR43, 0x5F - hw.read(REG_DIV) % 5)
            hw.write(NR44, 0x81)
            if shotX == 255 {
                shotDir = playerDir
                shotY = playerY + 7
                shotLife = 255
                switch playerDir {
                    case 0 {
                        shotX = playerX + 8
                        sprite.set_prop(11, 0)
                        playerX -= 2
                    }
                    default {
                        shotX = playerX
                        sprite.set_prop(11, FLIP_X)
                        playerX += 2
                    }
                }
                moveOAM(11, shotX, shotY)
            }
            if thrustAmount != 32 {
                thrustAmount += 2
            }
            show_flame()
        } else {
            hw.write(NR41, 0)
            hw.write(NR42, 0)
            hw.write(NR43, 0)
            hw.write(NR44, 0)
            if thrustAmount != -64 and thrustAmount != 66 {
                thrustAmount -= 4
            }
            hide_flame()
        }
        if shotX != 255 {
            switch shotDir {
                case 1 { shotX -= 1 }
                case 0 {
                    shotX += 1
                    if shotX == 180 { shotX = 255 }
                }
            }
            moveOAM(11, shotX, shotY)
        }
        if shotLife != 0 {
            shotLife -= 5
            hw.write(NR11, 0xC0)
            hw.write(NR12, 0x5F)
            hw.write(NR13, shotLife)
            hw.write(NR14, 0x87)
        } else {
            hw.write(NR11, 0)
            hw.write(NR12, 0)
            hw.write(NR13, 0)
            hw.write(NR14, 0)
        }
        playerVelocity += thrustAmount
        if playerVelocity > 192 {
            playerVelocity -= 64
            playerY -= 1
            update_distance()
            moveFlame += 1
            if playerY == 51 { playerY = 52 }
            if flameHeight != 140 and moveFlame % 2 == 1 { flameHeight += 1 }
            bkg.scroll(0, -1)
            update_scrolls()
            update_sprite()
        }
        if playerVelocity < 64 {
            playerVelocity += 64
            playerY += 1
            update_sprite()
        }
        if frame % 10 == 3 { flameHeight -= 1 }
        if frame % 10 == 7 { update_win_data() }
        moveOAM(20, enemyX[0], enemyY[0])
        moveOAM(21, enemyX[0] + 8, enemyY[0])
        moveOAM(22, enemyX[0], enemyY[0] + 8)
        moveOAM(23, enemyX[0] + 8, enemyY[0] + 8)
        moveOAM(24, enemyX[1], enemyY[1])
        moveOAM(25, enemyX[2], enemyY[2])
        moveOAM(26, enemyX[2] + 8, enemyY[2])
        moveOAM(27, enemyX[3], enemyY[3])
        moveOAM(28, enemyX[3] + 6, enemyY[3])
        moveOAM(29, enemyX[4], enemyY[4])
        moveOAM(30, enemyX[4] - 6, enemyY[4])
        moveOAM(31, enemyX[5], enemyY[5])
        moveOAM(32, enemyX[5] + 6, enemyY[5])
        moveOAM(33, enemyX[6], enemyY[6])
        moveOAM(34, enemyX[6] - 6, enemyY[6])
        window.move(6 + hw.read(REG_DIV) % 2, flameHeight)
        video.show_sprites()
    }

    local function play_update() {
        playMusicPlease = 0
        if entering == 1 {
            sprite.set_data(0, 70, gameSprites)
            bkg.set_data(0, 40, bkgTiles)
            bkg.set_tiles(0, 0, 20, 32, gameBKG)
            play_init()
            entering = 0
            return
        }
        if levelStarted == 0 {
            play_intro()
        } else {
            play_game()
        }
        video.show_background()
        video.show_window()
    }

    -- === TITLE / HOWTO (rombank2.c) =========================================
    local function title_init() {
        kk = 0
        cooldown = 30
        lives = 3
        hw.write(NR41, 0)
        hw.write(NR42, 0)
        hw.write(NR43, 0)
        hw.write(NR44, 0)
        bkg.move(4, 0)
        bkg.set_data(0, 106, titlebktiles)
        bkg.set_tiles(0, 0, 21, 18, titlescreen)
        video.hide_sprites()
        video.hide_window()
        video.show_background()
        fade_in_bkg(8)
    }

    local function title_update() {
        if entering == 1 {
            title_init()
            entering = 0
        }
        playMusicPlease = 1
        kk += 1
        if kk == 400 { go_howto() }
        if cooldown > 0 {
            cooldown -= 1
        } else {
            if input.pressed(INPUT_A) {
                dist[0] = 5
                dist[1] = 0
                dist[2] = 9
                dist[3] = 9
                difficulty = 1
                win = 0
                playMusicPlease = 0
                go_play()
            }
            if input.pressed(INPUT_B) {
                dist[0] = 3
                dist[1] = 4
                dist[2] = 9
                dist[3] = 9
                difficulty = 0
                win = 0
                playMusicPlease = 0
                go_play()
            }
        }
    }

    local function howto_init() {
        cooldown = 30
        fade_out_bkg(8)
        bkg.set_tiles(0, 0, 20, 17, howToPlayMap)
        bkg.move(0, 0)
        fade_in_bkg(8)
    }

    local function howto_update() {
        if entering == 1 {
            howto_init()
            entering = 0
        }
        playMusicPlease = 0
        hw.write(NR21, 0)
        hw.write(NR22, 0)
        hw.write(NR23, 0)
        hw.write(NR24, 0)
        hw.write(NR11, 0)
        hw.write(NR12, 0)
        hw.write(NR13, 0)
        hw.write(NR14, 0)
        if cooldown > 0 {
            cooldown -= 1
        } else {
            if input.pressed(INPUT_A) or input.pressed(INPUT_B) {
                go_title()
            }
        }
    }

    -- === ENDING: win / game-over (rombank3.c) ==============================
    local function ending_init() {
        cooldown = 30
        if win == 1 {
            vj = 86
            vk = 109
            vl = 0
            sprite.set_data(0, 6, endSprites)
            for v in 0..40 {
                moveOAM(v, 0, 0)
            }
            vi = 125
            sprite.set_tile(0, 0)
            sprite.set_tile(1, 2)
            moveOAM(0, vj, vk)
            moveOAM(1, vj, vk + 8)
            hw.write(NR41, 0)
            hw.write(NR42, 0)
            hw.write(NR43, 0)
            hw.write(NR44, 0)
            bkg.move(0, 0)
            bkg.set_data(0, 110, youwinbkg)
            bkg.set_tiles(0, 0, 20, 18, endingscreen)
            video.hide_window()
            video.show_background()
            video.show_sprites()
            fade_in_bkg(255)
        } else {
            bkg.move(0, 0)
            bkg.set_data(0, 110, youwinbkg)
            bkg.set_tiles(0, 0, 20, 18, gameOverMap)
            video.hide_sprites()
            video.hide_window()
            video.show_background()
            fade_in_bkg(255)
        }
    }

    local function ending_win() {
        video.show_background()
        video.show_sprites()
        video.hide_window()
        if vk != 0 {
            vl += 5
            if vl > vi {
                vl = 0
                vi -= 1
                if vi < 32 { vi = 32 }
                vk -= 1
                hw.write(NR41, 0x7F)
                hw.write(NR42, vk / 2)
                hw.write(NR43, 0x3F - hw.read(REG_DIV) % 3)
                hw.write(NR44, 0x81)
                if vk < 76 {
                    sprite.set_tile(0, 1)
                    sprite.set_tile(1, 2 + hw.read(REG_DIV) % 3)
                }
                moveOAM(0, vj, vk)
                moveOAM(1, vj, vk + 8)
            }
            system.delay(4)
        }
        if cooldown > 0 {
            cooldown -= 1
        } else {
            if input.pressed(INPUT_A) or input.pressed(INPUT_B) {
                fade_out_bkg(255)
                go_title()
            }
        }
    }

    local function ending_over() {
        hw.write(NR41, 0x7F)
        hw.write(NR42, 0x1F)
        hw.write(NR43, 0x6F - hw.read(REG_DIV) % 5)
        hw.write(NR44, 0x81)
        system.delay(2)
        if cooldown > 0 {
            cooldown -= 1
        } else {
            if input.pressed(INPUT_A) or input.pressed(INPUT_B) {
                fade_out_bkg(128)
                go_title()
            }
        }
    }

    local function ending_update() {
        if entering == 1 {
            ending_init()
            entering = 0
            return
        }
        if win == 1 {
            ending_win()
        } else {
            ending_over()
        }
    }

    -- === dispatcher + main loop ============================================
    local function update() {
        switch state {
            case 0 { title_update() }
            case 1 { howto_update() }
            case 2 { play_update() }
            default { ending_update() }
        }
    }

    function main() {
        hw.write(NR52, 0x8F)
        hw.write(NR51, 0xFF)
        hw.write(NR50, 0x01)
        system.seed_random(hw.read(REG_DIV))
        video.enable_lcd()
        state = 0
        entering = 1
        loop {
            frame += 1
            update()
            if playMusicPlease != 0 {
                play_music()
            }
            video.wait_vblank()
        }
    }


    } else {
        function main() {
            video.enable_lcd()
            loop { video.wait_vblank() }
        }
    }

    export main

}
